# workflow.kvx — the PORTABLE, IDE-neutral agent operating contract.
#
# This is the single source of truth for HOW an agent works a Matrix spec,
# across every IDE (Cursor, Windsurf, Claude Code, Kiro, Codex, Copilot, ...).
# The per-IDE rule files (.cursor/rules, .windsurf, CLAUDE.md, AGENTS.md, ...)
# are GENERATED from this file by spec/specgen — never hand-edit them.
#
# Format: sectioned KV per the Matrix .kvx convention (see
# tachyon/internal/config/kvx.go). String values are ALWAYS double-quoted.
#   [section] / [section.sub]   key = "string"   num = 80   list = ["a","b"]
# Comments start with # outside quotes. One key = value per line.

[meta]
name            = "Matrix Spec Workflow"
kind            = "portable-agent-operating-contract"
version         = "1.0.0"
status          = "active"
source_of_truth = "spec/ (kvx). Per-IDE rule files are GENERATED pointers — never hand-edit; run spec/specgen to regenerate."
active_feature  = "construct-os-shell"

[principle]
recall_first    = "Before any substantive work, run cortex_recall (MCP) once; treat HARD rules as inviolable and recalled facts/preferences as authoritative prior context."
ground_truth    = "cortex is durable ground truth across sessions; the spec .kvx is the durable plan for the current feature; the context window is a disposable cache."
task_driven     = "Work is driven by the active feature's spec.kvx task list — not ad-hoc. Pick the next eligible task by dependency wave, do it, mark it, move on."
one_in_progress = "At most ONE task is in_progress at a time. Set it to in_progress before starting, to done only when it genuinely meets the bar."
no_false_success= "Never mark a task done or attest completion that did not happen. Surface honest partials. A green test driven by a fake is not done."
read_full       = "When a tool output is flagged truncated/paginated with a way to get the rest, retrieve the full content before reasoning. An information gap is a stop condition."
deliver_complete= "Deliver complete, runnable artifacts, not diffs. Follow existing repo style; add no comments/docs unless asked."

[loop]
step_1 = "cortex_recall — load identity, HARD rules, preferences, recent outcomes."
step_2 = "Read spec/<active_feature>/spec.kvx — the [meta] status, [req.*] (acceptance criteria), and the [task.*] list with status + wave + requires."
step_3 = "Select the next eligible task: lowest wave whose every 'requires' task is done and whose status is pending. Set its status to in_progress in spec.kvx."
step_4 = "Before any destructive/irreversible/prod/secret/network-write action, run cortex_guard and self-check against HARD rules; stop for explicit user YES if it risks a HARD rule."
step_5 = "Implement the task against its referenced acceptance criteria (the 'reqs' clause ids in [req.*]). Verify with real tests/checks, not fakes."
step_6 = "On genuine completion: set the task status to done in spec.kvx, then cortex_note_outcome (success|partial|failure) with a terse summary."
step_7 = "Persist durable learnings as they occur: cortex_remember_{decision,constraint,fact,preference}. Then loop to step_3 until all tasks are done."

[cortex]
recall       = "cortex_recall at session start (load-bearing bootstrap)."
search       = "cortex_search mid-task to PULL targeted memory as you reason; narrow the query as you learn."
guard        = "cortex_guard before destructive / irreversible / security-sensitive / external-effect actions (fail-closed)."
note_outcome = "cortex_note_outcome after each completed task (result = success|partial|failure)."
remember     = "cortex_remember_decision / _constraint / _fact / _preference the moment something durable is learned or stated."
never        = "Never store secrets/tokens/keys/.env values in cortex. If recall conflicts with the live conversation, the live conversation wins — then update memory."

[status_values]
task    = ["pending", "in_progress", "done"]
feature = ["draft", "in_progress", "blocked", "complete"]

# HARD rules mirrored in-repo so an agent without cortex still sees them.
# These mirror the cortex HARD ruleset; cortex_recall is still authoritative.
[hard_rules]
task_durability = "Once a task is dispatched, keep at least one agent alive until it is done to the highest standard; decouple task lifecycle from the user's connection; on failure, bring up a fresh agent and continue. 'Done' means it genuinely meets the quality bar."
no_fakes        = "Never write stub/mock/fake test doubles or placeholder implementations to make tests pass. Test REAL code paths with REAL types."
read_full       = "When tool output is truncated and the rest is retrievable, fetch the full content before reasoning or answering."
no_git          = "Do not git commit/push on the dev box; the user drives commits. Uncommitted/untracked state is expected — never flag it as a problem."
ui_no_borders   = "Client UI: never use border strokes for depth/separation — separation comes purely from background-color contrast between layers."
ui_no_emojis    = "No emojis, purple gradients, or glow effects in UI or output."
gideon_validator= "Never touch the validator cluster 147.93.139.18 for any write/restart/exec unless explicitly named."
gideon_chainloss= "Any op risking total chain-state loss needs the user's explicit YES via a forced gate; never auto-approved."

# Generation config: which IDE adapter files specgen emits, and where the
# human-readable markdown mirror is rendered. Paths are repo-relative.
[render]
markdown_mirror  = true   
mirror_to_kiro   = true
banner           = "GENERATED by spec/specgen from spec/ kvx — DO NOT EDIT. Edit the .kvx source and regenerate."

[adapters]
# label = "output path"   (specgen wraps the shared brief in each IDE's native shape)
cursor            = ".cursor/rules/spec-workflow.mdc"
windsurf_rules    = ".windsurf/rules/spec-workflow.md"
windsurf_workflow = ".windsurf/workflows/spec.md"
claude            = "CLAUDE.md"
codex             = "AGENTS.md"
copilot           = ".github/copilot-instructions.md"
kiro              = ".kiro/steering/spec-workflow.md"
